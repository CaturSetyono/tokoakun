---
interface Props {
  id: string;
  title: string;
  category: string;
  price: number;
  sellerName: string;
  thumbnailUrl?: string;
}

const { id, title, category, price, sellerName, thumbnailUrl } = Astro.props;

const formatted = new Intl.NumberFormat('id-ID', {
  style: 'currency',
  currency: 'IDR',
  minimumFractionDigits: 0,
}).format(price);
---

<div class="account-card card">
  <!-- Thumbnail -->
  <div style="width:100%; aspect-ratio:4/3; background:var(--bg-secondary); border-radius:10px; overflow:hidden; margin-bottom:14px;">
    {thumbnailUrl
      ? <img src={thumbnailUrl} alt={title} style="width:100%; height:100%; object-fit:cover;" loading="lazy" />
      : <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; font-size:40px;">🎮</div>
    }
  </div>

  <!-- Category badge -->
  <span style="font-size:11px; font-weight:600; color:var(--accent); background:rgba(166,255,0,0.1); padding:3px 10px; border-radius:20px; text-transform:uppercase; letter-spacing:0.05em;">
    {category}
  </span>

  <!-- Title -->
  <h3 style="font-size:15px; font-weight:600; margin:8px 0 4px; color:var(--text-primary); line-height:1.4;">
    {title}
  </h3>

  <!-- Seller -->
  <p style="font-size:12px; color:var(--text-secondary); margin:0 0 12px;">
    by {sellerName}
  </p>

  <!-- Price + Buy -->
  <div style="display:flex; align-items:center; justify-content:space-between; margin-top:auto;">
    <span style="font-size:16px; font-weight:700; color:var(--text-primary);">
      {formatted}
    </span>
    <a href={`/shop/${id}`} class="btn-accent" style="padding:8px 14px; font-size:12px;">
      Beli
    </a>
  </div>
</div>

<style>
  .account-card {
    padding: 16px;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .account-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
  }
</style>
