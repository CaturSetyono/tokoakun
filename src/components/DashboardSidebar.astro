---
import { LayoutDashboard, Folder, CheckCircle, ShoppingCart, CircleDollarSign, Settings, Home, Package, Users, LineChart, Hash, LogOut } from 'lucide-astro';

interface Props {
  role: 'admin' | 'buyer';
  activeMenu?: string;
}

const { role, activeMenu = '' } = Astro.props;

const menus: Record<string, { label: string; href: string; icon: any }[]> = {
  buyer: [
    // Buyer dashboard sudah dihapus; hanya akses ke shop
    { label: 'Browse Shop', href: '/shop', icon: ShoppingCart },
  ],
  admin: [
    { label: 'Dashboard', href: '/dashboard/admin', icon: LayoutDashboard },
    { label: 'User Management', href: '/dashboard/admin/users', icon: Users },
    { label: 'Orders', href: '/dashboard/admin/orders', icon: Package },
    // Fitur yang sebelumnya di dashboard seller dipindah ke admin
    { label: 'Manage Accounts', href: '/dashboard/seller/accounts', icon: Folder },
    { label: 'Sold Accounts', href: '/dashboard/seller/sold', icon: CheckCircle },
    { label: 'Revenue', href: '/dashboard/seller/revenue', icon: CircleDollarSign },
  ],
};

const items = menus[role] ?? menus.admin;
---

<aside id="sidebar">
  <!-- Logo -->
  <div style="padding:24px 20px 32px;">
    <a href="/" style="font-size:18px; font-weight:700; text-decoration:none;">
      <span class="gradient-text">TOKO</span><span style="color:var(--text-primary);">AKUN</span>
    </a>
    <div style="margin-top:4px; font-size:11px; color:var(--text-secondary); text-transform:uppercase; letter-spacing:0.05em;">
      {role} panel
    </div>
  </div>

  <!-- Menu items -->
  <nav style="flex:1; padding:0 12px;">
    {items.map(item => {
      const Icon = item.icon;
      return (
      <a
        href={item.href}
        class={`sidebar-link ${activeMenu === item.label ? 'active' : ''}`}
      >
        <span style="display:flex; align-items:center;"><Icon size={18} strokeWidth={2} /></span>
        <span>{item.label}</span>
      </a>
      )
    })}
  </nav>

  <!-- Logout -->
  <div style="padding:16px 12px;">
    <button id="sidebar-logout" class="sidebar-link" style="width:100%; border:none; cursor:pointer; background:none; text-align:left;">
      <span style="display:flex; align-items:center;"><LogOut size={18} /></span>
      <span>Logout</span>
    </button>
  </div>
</aside>

<style>
  #sidebar {
    width: 240px;
    min-height: 100vh;
    background: var(--card-bg);
    border-right: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
    position: sticky;
    top: 0;
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-radius: 10px;
    text-decoration: none;
    color: var(--text-secondary);
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 4px;
    transition: all 0.2s;
  }
  .sidebar-link:hover {
    background: var(--bg-secondary);
    color: var(--text-primary);
  }
  .sidebar-link.active {
    background: var(--accent);
    color: #111111;
  }
</style>

<script>
  document.getElementById('sidebar-logout')?.addEventListener('click', async () => {
    await fetch('/api/auth/logout', { method: 'POST' });
    window.location.href = '/login';
  });

</script>
