---
import DashboardLayout from '../../../../../layouts/DashboardLayout.astro';
import { supabaseAdmin } from '../../../../../lib/supabaseAdmin';

const { id } = Astro.params;

const { data: product } = await supabaseAdmin
  .from('products')
  .select('id, title, niche, slug')
  .eq('id', id!)
  .maybeSingle();

if (!product) return Astro.redirect('/dashboard/admin/products');
if (product.niche !== 'premium_apps') {
  return Astro.redirect(`/dashboard/admin/products/${product.id}/edit`);
}

const { data: variants } = await supabaseAdmin
  .from('product_variants')
  .select(`
    id, name, status, is_unlimited_stock,
    product_credentials(id, email, password, status, delivered_at, created_at)
  `)
  .eq('product_id', product.id)
  .order('sort_order', { ascending: true });

const statusBadge: Record<string, string> = {
  available: 'background:rgba(34,197,94,0.1); color:#22c55e;',
  reserved: 'background:rgba(234,179,8,0.1); color:#eab308;',
  delivered: 'background:rgba(156,163,175,0.1); color:#9ca3af;',
};
---

<DashboardLayout title={`Credentials: ${product.title}`} role="admin" activeMenu="Products">
  <div style="max-width:960px;">
    <div style="margin-bottom:20px;">
      <a href={`/dashboard/admin/products/${product.id}/edit`} style="font-size:12px; color:var(--text-secondary); text-decoration:none;">← Kembali ke Produk</a>
    </div>
    <h1 style="font-size:24px; font-weight:700; margin:0 0 4px;">{product.title}</h1>
    <p style="color:var(--text-secondary); font-size:13px; margin:0 0 24px;">Kelola kredensial Premium Apps per variant</p>

    {variants && variants.length > 0 ? variants.map((v) => {
      const creds = (v as any).product_credentials ?? [];
      const available = creds.filter((c: any) => c.status === 'available').length;
      return (
        <div class="card" style="padding:20px; margin-bottom:20px;">
          <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
            <div>
              <h3 style="font-size:16px; font-weight:600; margin:0 0 2px;">{v.name}</h3>
              <div style="font-size:12px; color:var(--text-secondary);">
                {creds.length} total · {available} tersedia
              </div>
            </div>
            <button type="button" class="btn-accent bulk-add-btn" data-variant-id={v.id}>+ Bulk Add</button>
          </div>

          {creds.length > 0 ? (
            <table style="width:100%; border-collapse:collapse;">
              <thead>
                <tr style="border-bottom:1px solid var(--border-color);">
                  <th class="th">Email</th>
                  <th class="th">Password</th>
                  <th class="th">Status</th>
                  <th class="th">Aksi</th>
                </tr>
              </thead>
              <tbody>
                {creds.map((c: any) => (
                  <tr class="row" data-cred-id={c.id}>
                    <td class="td" style="font-family:monospace; font-size:12px;">{c.email}</td>
                    <td class="td" style="font-family:monospace; font-size:12px;">{'•'.repeat(Math.min(10, c.password.length))} <button class="reveal-btn" type="button" data-pwd={c.password} style="font-size:10px; border:none; background:transparent; color:var(--accent); cursor:pointer;">show</button></td>
                    <td class="td">
                      <span style={`font-size:11px; padding:2px 8px; border-radius:999px; font-weight:600; ${statusBadge[c.status] ?? ''}`}>
                        {c.status}
                      </span>
                    </td>
                    <td class="td">
                      {c.status === 'available' && (
                        <button type="button" class="delete-cred btn-outline" style="font-size:11px; padding:4px 8px; color:#ef4444;">Hapus</button>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          ) : (
            <div style="color:var(--text-secondary); font-size:13px; padding:20px; text-align:center;">Belum ada kredensial</div>
          )}
        </div>
      );
    }) : (
      <div class="card" style="padding:40px; text-align:center; color:var(--text-secondary);">
        Belum ada variant. Tambah variant dulu di halaman Variants.
      </div>
    )}
  </div>

  <!-- Bulk-add modal -->
  <div id="bulk-modal" class="modal-overlay" style="display:none;">
    <div class="modal-card card">
      <h3 style="font-size:16px; font-weight:600; margin:0 0 6px;">Bulk Add Credentials</h3>
      <p style="font-size:12px; color:var(--text-secondary); margin:0 0 16px;">Format per baris: <code>email:password</code></p>
      <textarea id="bulk-lines" rows="10" class="input" placeholder="netflix@example.com:pass123&#10;spotify@example.com:abcxyz"></textarea>
      <div id="bulk-error" style="display:none; margin-top:10px; padding:10px; border-radius:8px; background:rgba(239,68,68,0.1); color:#ef4444; font-size:12px;"></div>
      <div style="display:flex; gap:8px; justify-content:flex-end; margin-top:16px;">
        <button type="button" id="bulk-cancel" class="btn-outline">Batal</button>
        <button type="button" id="bulk-submit" class="btn-accent">Tambahkan</button>
      </div>
    </div>
  </div>
</DashboardLayout>

<style>
  .th { padding:10px 12px; text-align:left; font-size:11px; font-weight:600; color:var(--text-secondary); text-transform:uppercase; }
  .td { padding:10px 12px; border-bottom:1px solid var(--border-color); font-size:13px; }
  .row:last-child .td { border-bottom: none; }
  .row:hover { background: var(--bg-secondary); }
  .input {
    width:100%; padding:10px 14px;
    border:1px solid var(--border-color); border-radius:10px;
    background:var(--bg-secondary); color:var(--text-primary);
    font-family:monospace; font-size:13px;
  }
  .modal-overlay {
    position:fixed; inset:0; background:rgba(0,0,0,0.5);
    display:flex; align-items:center; justify-content:center; z-index:200;
  }
  .modal-card { width:100%; max-width:560px; padding:24px; }
</style>

<script>
  let activeVariantId: string | null = null;
  const modal = document.getElementById('bulk-modal') as HTMLElement;
  const linesInput = document.getElementById('bulk-lines') as HTMLTextAreaElement;
  const errorBox = document.getElementById('bulk-error') as HTMLElement;

  document.querySelectorAll<HTMLButtonElement>('.bulk-add-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      activeVariantId = btn.dataset.variantId ?? null;
      errorBox.style.display = 'none';
      linesInput.value = '';
      modal.style.display = 'flex';
    });
  });

  document.getElementById('bulk-cancel')?.addEventListener('click', () => { modal.style.display = 'none'; });
  modal.addEventListener('click', (e) => { if (e.target === modal) modal.style.display = 'none'; });

  document.getElementById('bulk-submit')?.addEventListener('click', async () => {
    if (!activeVariantId) return;
    errorBox.style.display = 'none';
    const lines = linesInput.value.split('\n').map((l) => l.trim()).filter(Boolean);
    if (lines.length === 0) {
      errorBox.textContent = 'Masukkan minimal 1 baris';
      errorBox.style.display = 'block';
      return;
    }
    try {
      const res = await fetch('/api/admin/credentials/bulk', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ variantId: activeVariantId, lines }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Gagal');
      window.location.reload();
    } catch (err: any) {
      errorBox.textContent = err.message;
      errorBox.style.display = 'block';
    }
  });

  document.querySelectorAll<HTMLButtonElement>('.reveal-btn').forEach((b) => {
    b.addEventListener('click', (e) => {
      const btn = e.currentTarget as HTMLButtonElement;
      const td = btn.closest('td')!;
      td.innerHTML = `<span style="font-family:monospace; font-size:12px;">${btn.dataset.pwd}</span>`;
    });
  });

  document.querySelectorAll<HTMLButtonElement>('.delete-cred').forEach((b) => {
    b.addEventListener('click', async (e) => {
      const row = (e.currentTarget as HTMLElement).closest('tr') as HTMLElement;
      const id = row.dataset.credId;
      if (!id || !confirm('Hapus credential ini?')) return;
      const res = await fetch(`/api/admin/credentials/${id}`, { method: 'DELETE' });
      if (res.ok) row.remove();
      else {
        const data = await res.json();
        alert(data.error || 'Gagal');
      }
    });
  });
</script>
