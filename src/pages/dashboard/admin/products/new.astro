---
import DashboardLayout from '../../../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Tambah Produk" role="admin" activeMenu="Products">
  <div style="max-width:720px;">
    <h1 style="font-size:24px; font-weight:700; margin:0 0 4px;">Tambah Produk Baru</h1>
    <p style="color:var(--text-secondary); font-size:14px; margin:0 0 28px;">Pilih niche dulu, lalu isi detail produk.</p>

    <form id="product-form" class="card" style="padding:28px; display:flex; flex-direction:column; gap:20px;">
      <div>
        <label class="label">Niche <span style="color:#ef4444;">*</span></label>
        <div class="niche-picker">
          <label class="niche-option">
            <input type="radio" name="niche" value="social_media" required />
            <div>
              <div class="emoji">📱</div>
              <div class="niche-title">Social Media Solution</div>
              <div class="niche-desc">Followers, likes, views (stok unlimited)</div>
            </div>
          </label>
          <label class="niche-option">
            <input type="radio" name="niche" value="premium_apps" />
            <div>
              <div class="emoji">🎬</div>
              <div class="niche-title">Premium Apps</div>
              <div class="niche-desc">Netflix, Spotify (stok dari kredensial)</div>
            </div>
          </label>
          <label class="niche-option">
            <input type="radio" name="niche" value="jasa" />
            <div>
              <div class="emoji">🛠️</div>
              <div class="niche-title">Jasa</div>
              <div class="niche-desc">Desain, dev, editing (stok unlimited)</div>
            </div>
          </label>
        </div>
      </div>

      <div>
        <label class="label" for="title">Judul Produk <span style="color:#ef4444;">*</span></label>
        <input type="text" id="title" name="title" required class="input" maxlength="180" />
      </div>

      <div>
        <label class="label" for="slug">Slug (opsional)</label>
        <input type="text" id="slug" name="slug" class="input" placeholder="Auto dari judul jika kosong" />
      </div>

      <div>
        <label class="label" for="description">Deskripsi</label>
        <textarea id="description" name="description" rows="5" class="input" placeholder="Markdown didukung"></textarea>
      </div>

      <div>
        <label class="label" for="thumbnailUrl">Thumbnail URL</label>
        <input type="url" id="thumbnailUrl" name="thumbnailUrl" class="input" placeholder="https://..." />
      </div>

      <div style="display:flex; gap:16px; align-items:center;">
        <label style="display:flex; align-items:center; gap:8px; font-size:13px;">
          <input type="checkbox" id="featured" name="featured" />
          Tampilkan sebagai featured
        </label>

        <label style="display:flex; align-items:center; gap:8px; font-size:13px;">
          Status
          <select id="status" name="status" class="input" style="width:auto;">
            <option value="draft">Draft</option>
            <option value="active">Active</option>
          </select>
        </label>
      </div>

      <div id="error-box" style="display:none; padding:12px; border-radius:10px; background:rgba(239,68,68,0.1); color:#ef4444; font-size:13px;"></div>

      <div style="display:flex; gap:12px; justify-content:flex-end; padding-top:8px;">
        <a href="/dashboard/admin/products" class="btn-outline">Batal</a>
        <button type="submit" class="btn-accent">Simpan & Lanjut ke Variants</button>
      </div>
    </form>
  </div>
</DashboardLayout>

<style>
  .label { font-size:13px; font-weight:500; display:block; margin-bottom:8px; color:var(--text-secondary); }
  .input {
    width:100%; padding:10px 14px;
    border:1px solid var(--border-color); border-radius:10px;
    background:var(--bg-secondary); color:var(--text-primary);
    font-family:inherit; font-size:14px;
  }
  .input:focus { outline:none; border-color:var(--accent); }

  .niche-picker { display:grid; grid-template-columns:repeat(3, 1fr); gap:12px; }
  .niche-option {
    display:flex; gap:10px; padding:14px; cursor:pointer;
    border:1px solid var(--border-color); border-radius:12px;
    background: var(--bg-secondary);
    transition: all 0.15s;
  }
  .niche-option:hover { border-color: var(--accent); }
  .niche-option:has(input:checked) {
    border-color: var(--accent);
    background: rgba(232,40,61,0.08);
  }
  .niche-option input { margin-top:3px; accent-color: var(--accent); }
  .emoji { font-size: 22px; margin-bottom: 4px; }
  .niche-title { font-size:13px; font-weight:600; }
  .niche-desc { font-size:11px; color:var(--text-secondary); margin-top:2px; }
</style>

<script>
  const form = document.getElementById('product-form') as HTMLFormElement;
  const errorBox = document.getElementById('error-box') as HTMLElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorBox.style.display = 'none';

    const fd = new FormData(form);
    const payload = {
      niche: fd.get('niche'),
      title: fd.get('title'),
      slug: (fd.get('slug') as string) || undefined,
      description: (fd.get('description') as string) || undefined,
      thumbnailUrl: (fd.get('thumbnailUrl') as string) || undefined,
      status: fd.get('status'),
      featured: fd.get('featured') === 'on',
    };

    if (!payload.niche) {
      errorBox.textContent = 'Pilih niche dulu';
      errorBox.style.display = 'block';
      return;
    }

    const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]')!;
    btn.disabled = true;
    btn.textContent = 'Menyimpan...';

    try {
      const res = await fetch('/api/admin/products', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Gagal menyimpan');
      window.location.href = `/dashboard/admin/products/${data.id}/variants`;
    } catch (err: any) {
      errorBox.textContent = err.message;
      errorBox.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Simpan & Lanjut ke Variants';
    }
  });
</script>
