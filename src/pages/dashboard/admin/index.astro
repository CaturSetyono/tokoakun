---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { supabase } from '../../../lib/supabase';

const { count: totalUsers } = await supabase
  .from('users')
  .select('*', { count: 'exact', head: true });

const { count: totalOrders } = await supabase
  .from('orders')
  .select('*', { count: 'exact', head: true });

const { count: paidOrders } = await supabase
  .from('orders')
  .select('*', { count: 'exact', head: true })
  .eq('status', 'paid');

const { count: totalAccounts } = await supabase
  .from('accounts')
  .select('*', { count: 'exact', head: true });

const { count: soldAccounts } = await supabase
  .from('accounts')
  .select('*', { count: 'exact', head: true })
  .eq('status', 'sold');
---

<DashboardLayout title="Admin Dashboard" role="admin" activeMenu="Dashboard">
  <div>
    <h1 style="font-size:24px; font-weight:700; margin:0 0 6px;">Admin Dashboard</h1>
    <p style="color:var(--text-secondary); font-size:14px; margin:0 0 32px;">Platform overview</p>

    <div style="display:grid; grid-template-columns:repeat(5, 1fr); gap:16px; margin-bottom:32px;">
      {[
        { label: 'Total Users', value: totalUsers ?? 0, icon: '👥', color: '#3b82f6' },
        { label: 'Total Orders', value: totalOrders ?? 0, icon: '📦', color: '#8b5cf6' },
        { label: 'Paid Orders', value: paidOrders ?? 0, icon: '✅', color: '#22c55e' },
        { label: 'Total Accounts', value: totalAccounts ?? 0, icon: '🗂️', color: '#f59e0b' },
        { label: 'Accounts Sold', value: soldAccounts ?? 0, icon: '💰', color: '#a6ff00' },
      ].map(stat => (
        <div class="card" style="padding:20px;">
          <div style="font-size:22px; margin-bottom:10px;">{stat.icon}</div>
          <div style={`font-size:26px; font-weight:700; color:${stat.color};`}>{stat.value}</div>
          <div style="font-size:12px; color:var(--text-secondary); margin-top:4px;">{stat.label}</div>
        </div>
      ))}
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px;">
      <div class="card" style="padding:24px;">
        <h2 style="font-size:16px; font-weight:600; margin:0 0 16px;">Quick Links</h2>
        <div style="display:flex; flex-direction:column; gap:10px;">
          <a href="/dashboard/admin/users" class="btn-outline" style="font-size:13px; text-align:center;">👥 User Management</a>
          <a href="/dashboard/admin/orders" class="btn-outline" style="font-size:13px; text-align:center;">📦 All Orders</a>
          <a href="/dashboard/admin/sellers" class="btn-outline" style="font-size:13px; text-align:center;">📈 Seller Analytics</a>
        </div>
      </div>

      <div class="card" style="padding:24px;">
        <h2 style="font-size:16px; font-weight:600; margin:0 0 16px;">Status Ringkasan</h2>
        <div style="display:flex; flex-direction:column; gap:12px; font-size:14px;">
          <div style="display:flex; justify-content:space-between;">
            <span style="color:var(--text-secondary);">Order success rate</span>
            <span style="font-weight:600; color:#22c55e;">{totalOrders ? Math.round(((paidOrders ?? 0) / totalOrders) * 100) : 0}%</span>
          </div>
          <div style="display:flex; justify-content:space-between;">
            <span style="color:var(--text-secondary);">Accounts sold rate</span>
            <span style="font-weight:600; color:#a6ff00;">{totalAccounts ? Math.round(((soldAccounts ?? 0) / totalAccounts) * 100) : 0}%</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>
