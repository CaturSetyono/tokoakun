---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { supabase } from '../../../lib/supabase';
import { ShoppingCart, Package } from 'lucide-astro';

const { data: { user } } = await supabase.auth.getUser();

const { count: totalOrders } = await supabase
  .from('orders')
  .select('*', { count: 'exact', head: true })
  .eq('buyer_id', user?.id ?? '');

const { count: paidOrders } = await supabase
  .from('orders')
  .select('*', { count: 'exact', head: true })
  .eq('buyer_id', user?.id ?? '')
  .eq('status', 'paid');
---

<DashboardLayout title="Buyer Dashboard" role="buyer" activeMenu="Dashboard">
  <div>
    <h1 style="font-size:24px; font-weight:700; margin:0 0 6px;">Dashboard</h1>
    <p style="color:var(--text-secondary); font-size:14px; margin:0 0 32px;">Selamat datang, {user?.email}</p>

    <div style="display:grid; grid-template-columns:repeat(2, 1fr); gap:20px; margin-bottom:32px;">
      <div class="card" style="padding:24px;">
        <div style="font-size:13px; color:var(--text-secondary); margin-bottom:12px;">Total Pesanan</div>
        <div style="font-size:32px; font-weight:700; color:#3b82f6;">{totalOrders ?? 0}</div>
      </div>
      <div class="card" style="padding:24px;">
        <div style="font-size:13px; color:var(--text-secondary); margin-bottom:12px;">Pesanan Selesai</div>
        <div style="font-size:32px; font-weight:700; color:#22c55e;">{paidOrders ?? 0}</div>
      </div>
    </div>

    <div class="card" style="padding:24px;">
      <h2 style="font-size:16px; font-weight:600; margin:0 0 16px;">Aksi Cepat</h2>
      <div style="display:flex; gap:12px; flex-wrap:wrap;">
        <a href="/shop" class="btn-accent" style="font-size:13px; display:inline-flex; align-items:center; gap:8px;"><ShoppingCart size={16} /> Browse Shop</a>
        <a href="/dashboard/buyer/orders" class="btn-outline" style="font-size:13px; display:inline-flex; align-items:center; gap:8px;"><Package size={16} /> Lihat Pesanan</a>
      </div>
    </div>
  </div>
</DashboardLayout>
