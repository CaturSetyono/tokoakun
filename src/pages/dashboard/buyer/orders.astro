---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { supabaseAdmin } from '../../../lib/supabaseAdmin';
import { CheckCircle, Clock, PartyPopper, CreditCard, ShoppingBag } from 'lucide-astro';

const { userId } = Astro.locals;

// Orders for buyer
const { data: orders } = await supabaseAdmin
  .from('orders')
  .select(`
    id, total_price, status, created_at, mayar_payment_url,
    order_items(
      id, price,
      accounts(id, title, category, email_account, password_account, status)
    )
  `)
  .eq('buyer_id', userId || '')
  .order('created_at', { ascending: false });
---

<DashboardLayout title="My Orders" role="buyer" activeMenu="My Orders">
  <div>
    <div style="margin-bottom:28px;">
      <h1 style="font-size:24px; font-weight:700; margin:0 0 4px;">Pesanan Saya</h1>
      <p style="color:var(--text-secondary); font-size:14px; margin:0;">{orders?.length ?? 0} pesanan</p>
    </div>

    {orders && orders.length > 0 ? (
      <div style="display:flex; flex-direction:column; gap:16px;">
        {orders.map((order: any) => {
          const totalFormatted = new Intl.NumberFormat('id-ID', { style:'currency', currency:'IDR', minimumFractionDigits:0 }).format(order.total_price);
          const date = new Date(order.created_at).toLocaleDateString('id-ID', { day:'numeric', month:'long', year:'numeric' });
          const isPaid = order.status === 'paid';
          return (
            <div class="card" style="padding:24px;">
              <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
                <div>
                  <span style="font-size:12px; color:var(--text-secondary);">Order #{order.id.slice(0, 8)}</span>
                  <div style="font-size:14px; color:var(--text-secondary); margin-top:2px;">{date}</div>
                </div>
                <div style="display:flex; align-items:center; gap:12px;">
                  <span style={`font-size:12px; padding:4px 12px; border-radius:20px; font-weight:600; display:inline-flex; align-items:center; gap:6px; background:${isPaid ? 'rgba(34,197,94,0.1)' : 'rgba(234,179,8,0.1)'}; color:${isPaid ? '#22c55e' : '#eab308'};`}>
                    {isPaid ? <CheckCircle size={14} /> : <Clock size={14} />}
                    {isPaid ? 'Lunas' : 'Menunggu Pembayaran'}
                  </span>
                  <span style="font-size:16px; font-weight:700;">{totalFormatted}</span>
                </div>
              </div>

              {order.order_items?.map((item: any) => {
                const acc = item.accounts;
                if (!acc) return null;
                return (
                  <div style="border:1px solid var(--border-color); border-radius:10px; padding:16px; margin-bottom:8px; background:var(--bg-secondary);">
                    <div style="display:flex; align-items:center; justify-content:space-between;">
                      <div>
                        <div style="font-size:14px; font-weight:600; margin-bottom:4px;">{acc.title}</div>
                        <span style="font-size:11px; background:rgba(166,255,0,0.1); color:var(--accent); padding:2px 8px; border-radius:20px;">{acc.category}</span>
                      </div>
                    </div>

                    {isPaid && (
                      <div style="margin-top:12px; padding:12px; background:rgba(34,197,94,0.05); border:1px solid rgba(34,197,94,0.2); border-radius:8px;">
                        <div style="font-size:12px; font-weight:600; color:#22c55e; margin-bottom:8px; display:flex; align-items:center; gap:6px;">
                          <PartyPopper size={14} /> Detail Akun
                        </div>
                        <div style="font-size:13px; color:var(--text-primary); margin-bottom:4px;">
                          <strong>Email:</strong> {acc.email_account}
                        </div>
                        <div style="font-size:13px; color:var(--text-primary);">
                          <strong>Password:</strong> {acc.password_account}
                        </div>
                      </div>
                    )}
                  </div>
                );
              })}

              {!isPaid && order.mayar_payment_url && (
                <a href={order.mayar_payment_url} target="_blank" rel="noopener noreferrer" class="btn-accent" style="font-size:13px; padding:10px 20px; display:inline-flex; align-items:center; gap:8px; margin-top:8px;">
                  <CreditCard size={16} /> Bayar Sekarang
                </a>
              )}
            </div>
          );
        })}
      </div>
    ) : (
      <div class="card" style="padding:60px; text-align:center; color:var(--text-secondary); display:flex; flex-direction:column; align-items:center;">
        <ShoppingBag size={48} strokeWidth={1.5} style="margin-bottom:16px; color:var(--text-secondary);" />
        <p style="font-size:16px;">Belum ada pesanan.</p>
        <a href="/shop" class="btn-accent" style="margin-top:16px; display:inline-block;">Browse Shop</a>
      </div>
    )}
  </div>
</DashboardLayout>
