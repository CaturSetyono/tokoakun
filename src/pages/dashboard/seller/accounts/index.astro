---
import DashboardLayout from '../../../../layouts/DashboardLayout.astro';
import { supabase } from '../../../../lib/supabase';
import { PackageOpen } from 'lucide-astro';

// Get current user's seller accounts
const { data: { user } } = await supabase.auth.getUser();

const { data: accounts } = await supabase
  .from('accounts')
  .select('id, title, category, price, status, created_at')
  .eq('seller_id', user?.id ?? '')
  .order('created_at', { ascending: false });
---

<DashboardLayout title="My Accounts" role="seller" activeMenu="My Accounts">
  <div>
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:28px;">
      <div>
        <h1 style="font-size:24px; font-weight:700; margin:0 0 4px;">My Accounts</h1>
        <p style="color:var(--text-secondary); font-size:14px; margin:0;">{accounts?.length ?? 0} akun</p>
      </div>
      <a href="/dashboard/seller/accounts/add" class="btn-accent">+ Tambah Akun</a>
    </div>

    <div class="card" style="overflow:hidden;">
      {accounts && accounts.length > 0 ? (
        <table style="width:100%; border-collapse:collapse;">
          <thead>
            <tr style="border-bottom:1px solid var(--border-color); background:var(--bg-secondary);">
              <th style="padding:14px 20px; text-align:left; font-size:12px; font-weight:600; color:var(--text-secondary); text-transform:uppercase; letter-spacing:0.05em;">Judul</th>
              <th style="padding:14px 20px; text-align:left; font-size:12px; font-weight:600; color:var(--text-secondary); text-transform:uppercase; letter-spacing:0.05em;">Kategori</th>
              <th style="padding:14px 20px; text-align:left; font-size:12px; font-weight:600; color:var(--text-secondary); text-transform:uppercase; letter-spacing:0.05em;">Harga</th>
              <th style="padding:14px 20px; text-align:left; font-size:12px; font-weight:600; color:var(--text-secondary); text-transform:uppercase; letter-spacing:0.05em;">Status</th>
              <th style="padding:14px 20px; text-align:left; font-size:12px; font-weight:600; color:var(--text-secondary); text-transform:uppercase; letter-spacing:0.05em;">Aksi</th>
            </tr>
          </thead>
          <tbody>
            {accounts.map((acc: any) => {
              const price = new Intl.NumberFormat('id-ID', { style:'currency', currency:'IDR', minimumFractionDigits:0 }).format(acc.price);
              return (
                <tr style="border-bottom:1px solid var(--border-color);" class="table-row">
                  <td style="padding:14px 20px; font-size:14px; font-weight:500; color:var(--text-primary);">{acc.title}</td>
                  <td style="padding:14px 20px;">
                    <span style="font-size:12px; background:rgba(166,255,0,0.1); color:var(--accent); padding:3px 10px; border-radius:20px; font-weight:600;">{acc.category}</span>
                  </td>
                  <td style="padding:14px 20px; font-size:14px; font-weight:600;">{price}</td>
                  <td style="padding:14px 20px;">
                    <span style={`font-size:12px; padding:3px 10px; border-radius:20px; font-weight:600; background:${acc.status === 'available' ? 'rgba(34,197,94,0.1)' : 'rgba(239,68,68,0.1)'}; color:${acc.status === 'available' ? '#22c55e' : '#ef4444'};`}>
                      {acc.status === 'available' ? '✓ Tersedia' : '✗ Terjual'}
                    </span>
                  </td>
                  <td style="padding:14px 20px;">
                    <div style="display:flex; gap:8px;">
                      {acc.status === 'available' && (
                        <a href={`/dashboard/seller/accounts/edit/${acc.id}`} class="btn-outline" style="padding:5px 12px; font-size:12px;">Edit</a>
                      )}
                      <button
                        class="btn-outline delete-btn"
                        data-id={acc.id}
                        style="padding:5px 12px; font-size:12px; color:#ef4444; border-color:#ef4444;"
                      >
                        Hapus
                      </button>
                    </div>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      ) : (
        <div style="text-align:center; padding:60px; color:var(--text-secondary); display:flex; flex-direction:column; align-items:center;">
          <PackageOpen size={48} strokeWidth={1.5} style="margin-bottom:12px; color:var(--text-secondary);" />
          <p>Belum ada akun. <a href="/dashboard/seller/accounts/add" style="color:var(--accent);">Tambah akun pertama →</a></p>
        </div>
      )}
    </div>
  </div>
</DashboardLayout>

<style>
  .table-row:hover { background: var(--bg-secondary); }
  .table-row:last-child { border-bottom: none; }
</style>

<script>
  import { supabase } from '../../../../lib/supabase';

  document.querySelectorAll<HTMLButtonElement>('.delete-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      if (!confirm('Hapus akun ini?')) return;
      const id = btn.dataset.id!;
      const { error } = await supabase.from('accounts').delete().eq('id', id);
      if (error) alert('Gagal menghapus: ' + error.message);
      else window.location.reload();
    });
  });
</script>
